{
  "kind": "collectionType",
  "collectionName": "research_subjects",
  "info": {
    "singularName": "research-subject",
    "pluralName": "research-subjects",
    "displayName": "考据对象",
    "description": "考据知识网络中的实体枢纽：学院、组织、人物、概念等"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "subject_type": {
      "type": "enumeration",
      "enum": ["school", "organization", "club", "character", "location", "concept", "item"],
      "default": "concept",
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "description": {
      "type": "richtext",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"],
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "students": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::student.student"
    },
    "entries": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::research-entry.research-entry",
      "inversedBy": "subjects"
    }
  }
}

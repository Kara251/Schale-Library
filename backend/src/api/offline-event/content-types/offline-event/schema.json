{
  "kind": "collectionType",
  "collectionName": "offline_events",
  "info": {
    "singularName": "offline-event",
    "pluralName": "offline-events",
    "displayName": "线下活动",
    "description": "线下活动管理"
  },
  "options": {
    "draftAndPublish": true,
    "comment": ""
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "nature": {
      "type": "enumeration",
      "enum": ["official", "fanmade"],
      "default": "official",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "eventFormat": {
      "type": "enumeration",
      "enum": ["stream", "stage", "only", "exhibition", "contest", "uncategorized", "live_stream", "live_show", "only_event", "collaboration", "campaign", "meetup", "release", "other"],
      "default": "uncategorized",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "statusOverride": {
      "type": "enumeration",
      "enum": ["normal", "postponed", "cancelled", "rescheduled", "ticketing", "sold_out", "changed"],
      "default": "normal",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "country": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "region": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "city": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "venue": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "address": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "location": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "mapUrl": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "guests": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "startTime": {
      "type": "datetime",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }

{
  "kind": "collectionType",
  "collectionName": "research_entries",
  "info": {
    "singularName": "research-entry",
    "pluralName": "research-entries",
    "displayName": "考据条目",
    "description": "考据档案主体内容"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "stance": {
      "type": "enumeration",
      "enum": ["official", "personal", "speculative"],
      "default": "personal",
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "summary": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "body": {
      "type": "richtext",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "media_type": {
      "type": "enumeration",
      "enum": ["character", "story", "concept", "setting", "organization"],
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "affiliations": {
      "type": "json",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "themes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::research-theme.research-theme",
      "inversedBy": "entries"
    },
    "citations": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::research-citation.research-citation",
      "inversedBy": "entries"
    },
    "related_links": {
      "type": "component",
      "repeatable": true,
      "component": "research.related-link"
    }
  }
}

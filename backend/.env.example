HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# PostgreSQL 推荐配置；生产环境默认禁止 SQLite，避免 serverless 重启后丢数据
DATABASE_CLIENT=postgres
DATABASE_URL=
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MIN=0
DATABASE_POOL_MAX=5
# 仅临时环境才允许生产 SQLite；正式部署保持 false
ALLOW_PRODUCTION_SQLITE=false

# RSSHub
RSSHUB_URL=http://localhost:1200
RSS_SYNC_CONCURRENCY=3

# 自研后台：生产环境必须配置维护角色和内部接口令牌
ADMIN_PANEL_ALLOWED_ROLES=maintainer,admin
PANEL_INTERNAL_TOKEN=change-me
RATE_LIMIT_HASH_SECRET=change-me-too
# 可选：显式恢复/创建自研后台维护账号。仅在需要重建维护账号时填写。
# ADMIN_PANEL_BOOTSTRAP_EMAIL=
# ADMIN_PANEL_BOOTSTRAP_USERNAME=maintainer
# ADMIN_PANEL_BOOTSTRAP_PASSWORD=

# 自研后台上传限制，单位 MB
ADMIN_PANEL_MAX_UPLOAD_MB=8
ADMIN_PANEL_AVATAR_MAX_UPLOAD_MB=4
ADMIN_PANEL_COVER_MAX_UPLOAD_MB=12

# Cloudinary 三项必须同时配置；留空时使用 Strapi 本地上传 provider
# CLOUDINARY_NAME=
# CLOUDINARY_KEY=
# CLOUDINARY_SECRET=

# Strapi 后端 API 地址
NEXT_PUBLIC_API_URL=http://localhost:8083

# 前端站点地址，用于登录回跳和同源后台接口
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 前端服务端调用 Strapi 内部接口的共享令牌；生产环境必须和 backend 一致
PANEL_INTERNAL_TOKEN=change-me

# 前端请求 Strapi 的默认超时，单位 ms
API_TIMEOUT_MS=10000

# 生产环境后台面板允许的 users-permissions 角色 type/name
ADMIN_PANEL_ALLOWED_ROLES=maintainer,admin
